# Copy this file to .env and fill in real values. Never commit the real .env file.

# Postgres connection (docker-compose sets host=db automatically)
DATABASE_URL=postgresql://matcher:matcher@db:5432/matcher

# JWT auth
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: enables LLM-generated explanations (strengths/gaps/rewrite suggestions).
# If left blank, the app still works and falls back to embedding-similarity-only scoring.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS - comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
